{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@sanbao/shared/*": ["../../packages/shared/src/*"],
      "@sanbao/stores/*": ["../../packages/stores/src/*"],
      "@sanbao/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src", "../../packages/*/src"]
}
