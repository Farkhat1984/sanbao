# Sanbao — Environment Variables
# Copy to .env and fill in real values

# Database (via PgBouncer)
DATABASE_URL="postgresql://postgres:PASSWORD@pgbouncer:5432/sanbao?schema=public&pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://postgres:PASSWORD@db:5432/sanbao?schema=public"

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=https://www.sanbao.ai

# Encryption (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=

# Google OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# LLM API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPINFRA_API_KEY=
MOONSHOT_API_KEY=

# Cron secret
CRON_SECRET=

# Admin
ADMIN_PASSWORD=
ADMIN_LOGIN=admin
ADMIN_EMAIL=admin@sanbao.local

# MCP endpoints (Docker internal)
LAWYER_MCP_URL=http://orchestrator:8120/lawyer
BROKER_MCP_URL=http://orchestrator:8120/broker
ACCOUNTINGDB_MCP_URL=http://orchestrator:8120/accountant
CONSULTANT_1C_MCP_URL=http://orchestrator:8120/consultant_1c
AI_CORTEX_AUTH_TOKEN=

# Redis
REDIS_URL=redis://redis:6379

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# S3 storage (optional)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# App
NODE_ENV=production
PORT=3004
