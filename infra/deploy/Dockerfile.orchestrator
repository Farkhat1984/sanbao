FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir \
    httpx==0.28.* \
    aiohttp==3.* \
    duckdb==1.* \
    reportlab==4.* \
    numpy \
    scikit-learn \
    pdfplumber \
    python-docx \
    PyMuPDF \
    openpyxl \
    PyJWT

COPY ai_cortex/orchestrator/ /app/orchestrator/
COPY ai_cortex/config/ /app/config/
COPY ai_cortex/data/accounting_ref_kz/ /app/data/accounting_ref_kz/
COPY ai_cortex/data/legal_reference_kz.csv /app/data/legal_reference_kz.csv
COPY ai_cortex/data/tnved/ /app/data/tnved/
COPY ai_cortex/data/customs/ /app/data/customs/

EXPOSE 8120

ENV LEEMADB_URL="http://leemadb:8080"
ENV AI_CORTEX_PORT="8120"
ENV AI_CORTEX_AUTH_TOKEN=""
ENV DEEPINFRA_API_KEY=""
ENV ANTHROPIC_API_KEY=""

RUN adduser --disabled-password --gecos '' appuser && \
    chown -R appuser:appuser /app/config /app/data
USER appuser

CMD ["python", "-m", "orchestrator", "--http"]
